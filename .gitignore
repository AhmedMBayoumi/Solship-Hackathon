*.tmp
*.scratch

# Run logs (large, regenerable)
outputs/reports/*_run.log
outputs/reports/*.log

# Feature parquets (regenerable from scripts; keep only the cols .txt manifests)
data/features/features_v*_all.parquet
data/features/features_v*_train.parquet
data/features/features_v*_val.parquet
data/features/features_v*_test.parquet
